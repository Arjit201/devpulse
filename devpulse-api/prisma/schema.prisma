generator client{
  provider = "prisma-client-js"
}
datasource db{
  provider = "postgresql"
  url = env("DATABASE_URL")
}
enum userRole{
  candidate
  recruiter
  company_admin
}
enum JobType{
  full_time
  part_time
  contract
  internship
}
enum JobStatus{
  open
  closed
  draft
}
enum ApplicationStage{
  applied
  screening
  interview
  offer
  hired
  rejected
}
enum InterviewFormat {
  phone
  video
  onsite
  take_home
}

enum InterviewStatus {
  scheduled
  completed
  cancelled
}

enum Recommendation {
  strong_yes
  yes
  no
  strong_no
}
model User{
  id String @id @default(uuid())
  email String @unique
  passwordHash String @map("password_hash")
  name String?
  role userRole @default(candidate)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  ownedCompany Company? @relation("CompanyOwner")
  recruiterProfile RecruiterProfile?
  candidateProfile CandidateProfile?
  postedJobs JobPosting[] @relation("JobPoster")
  stageTransitions    StageTransition[]  @relation("TransitionActor")
  scheduledInterviews Interview[]        @relation("InterviewScheduler")
  interviewFeedback   InterviewFeedback[] @relation("FeedbackReviewer")
  notifications       Notification[]
  @@map("users")
}

model Company{
  id String @id @default(uuid())
  ownerId String @unique @map("owner_id")
  name String
  slug String @unique
  website String?
  description String?
  createdAt DateTime @default(now()) @map("created_at")
  owner User @relation("CompanyOwner",fields:[ownerId],  references:[id])
  recruiters RecruiterProfile[]
  jobs JobPosting[]
  @@map("companies")
}
model RecruiterProfile{
  id String @id @default(uuid())
  userId String @unique @map("user_id")
  companyId String @map("company_id")
  title String?
  user User @relation(fields:[userId], references: [id], onDelete: Cascade)
  company Company @relation(fields:[companyId],references:[id],onDelete: Cascade)
  @@map("recruiter_profiles")
}
model CandidateProfile{
  id String @id @default(uuid())
  userId String @unique @map("user_id")
  headline String?
  bio String?
  resumeUrl String? @map("resume_url")
  skills String[]
  applications Application[]
  user User @relation(fields:[userId],references:[id],onDelete:Cascade)
  @@map("candidate_profiles")
}
model JobPosting{
  id String @id @default(uuid())
  companyId String @map("company_id")
  postedById String @map("posted_by")
  title String
  description String
  location String?
  status JobStatus @default(open)
  type JobType @default(full_time)
  salaryMin Int? @map("min_salary")
  salaryMax Int? @map("max_salary")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  company Company @relation(fields:[companyId], references:[id], onDelete: Cascade)
  postedBy User @relation("JobPoster",fields:[postedById], references:[id])
  applications Application[]
  @@index([status,createdAt(sort: Desc)])
  @@index([companyId])
  @@map("job_postings")
}
model Application{
  id String @id @default(uuid())
  jobId String @map("job_id")
  candidateId String @map("candidate_id")
  stage ApplicationStage @default(applied)
  coverLetter String? @map("cover_letter")
  resumeSnapshotUrl String? @map("resume_snapshot_url")
  appliedAt DateTime @default(now()) @map("applied_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  job JobPosting @relation(fields:[jobId],references:[id],onDelete:Cascade)
  candidate CandidateProfile @relation(fields:[candidateId],references:[id],onDelete:Cascade)
  stageTransitions StageTransition[]
  interviews       Interview[]
  @@unique([jobId,candidateId])
  @@index([jobId,stage])
  @@index([candidateId])
  @@map("applications")
}
model StageTransition {
  id            String           @id @default(uuid())
  applicationId String           @map("application_id")
  changedById   String           @map("changed_by")
  fromStage     ApplicationStage @map("from_stage")
  toStage       ApplicationStage @map("to_stage")
  note          String?
  createdAt     DateTime         @default(now()) @map("created_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  changedBy   User        @relation("TransitionActor", fields: [changedById], references: [id])

  @@index([applicationId, createdAt])
  @@map("stage_transitions")
}

model Interview {
  id              String          @id @default(uuid())
  applicationId   String          @map("application_id")
  scheduledById   String          @map("scheduled_by")
  format          InterviewFormat @default(video)
  scheduledAt     DateTime        @map("scheduled_at")
  durationMinutes Int             @default(60) @map("duration_minutes")
  meetingLink     String?         @map("meeting_link")
  status          InterviewStatus @default(scheduled)
  createdAt       DateTime        @default(now()) @map("created_at")

  application Application         @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  scheduledBy User                @relation("InterviewScheduler", fields: [scheduledById], references: [id])
  feedback    InterviewFeedback[]

  @@index([applicationId])
  @@map("interviews")
}

model InterviewFeedback {
  id             String         @id @default(uuid())
  interviewId    String         @map("interview_id")
  reviewerId     String         @map("reviewer_id")
  rating         Int
  strengths      String?
  concerns       String?
  recommendation Recommendation
  createdAt      DateTime       @default(now()) @map("created_at")

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  reviewer  User      @relation("FeedbackReviewer", fields: [reviewerId], references: [id])

  @@unique([interviewId, reviewerId])
  @@map("interview_feedback")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  payload   Json     @default("{}")
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt(sort: Desc)])
  @@map("notifications")
}
